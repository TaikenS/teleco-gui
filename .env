# ==============================
# teleco-gui shared defaults
# ==============================
# This file is safe to commit.
# Local/private overrides should go in .env.local.

# Next app HTTP port
PORT=3000

# Signaling WS port (if omitted, PORT is used)
SIGNAL_PORT=3000

# Optional: force client signaling destination explicitly
# NEXT_PUBLIC_SIGNALING_URL=ws://localhost:3000/ws

# Optional: only override signaling port on client side
NEXT_PUBLIC_SIGNALING_PORT=3000
# Optional: only override signaling IP/host on client side
NEXT_PUBLIC_SIGNALING_IP_ADDRESS=localhost

# Scoped signaling defaults (preferred)
# Audio Receiver (/audio)
NEXT_PUBLIC_AUDIO_RECEIVE_SIGNALING_IP_ADDRESS=localhost
NEXT_PUBLIC_AUDIO_RECEIVE_SIGNALING_PORT=3000
# Audio Sender (/audio/sender and /gui Device Setting audio send)
NEXT_PUBLIC_AUDIO_SEND_SIGNALING_IP_ADDRESS=localhost
NEXT_PUBLIC_AUDIO_SEND_SIGNALING_PORT=3000
# Video Sender (/video and /gui video webSender)
NEXT_PUBLIC_VIDEO_SEND_SIGNALING_IP_ADDRESS=localhost
NEXT_PUBLIC_VIDEO_SEND_SIGNALING_PORT=3000
# Video Receiver (/gui webSender receive)
NEXT_PUBLIC_VIDEO_RECEIVE_SIGNALING_IP_ADDRESS=localhost
NEXT_PUBLIC_VIDEO_RECEIVE_SIGNALING_PORT=3000

# Default rooms
NEXT_PUBLIC_DEFAULT_VIDEO_ROOM=operator1-video
NEXT_PUBLIC_DEFAULT_AUDIO_ROOM=operator1-audio

# teleco main endpoint defaults used by GUI
NEXT_PUBLIC_TELECO_IP_ADDRESS=localhost
NEXT_PUBLIC_TELECO_PORT=11920

# Camera tuning defaults
NEXT_PUBLIC_CAMERA_LEFT_EXPOSURE_COMPENSATION=0
NEXT_PUBLIC_CAMERA_RIGHT_EXPOSURE_COMPENSATION=0
NEXT_PUBLIC_CAMERA_LEFT_BRIGHTNESS=0
NEXT_PUBLIC_CAMERA_RIGHT_BRIGHTNESS=0
NEXT_PUBLIC_CAMERA_HEADING_STEP=0.25

# Video receiver speech cue frame defaults
NEXT_PUBLIC_VIDEO_SPEECH_CUE_FRAME_LEFT_PERCENT=34
NEXT_PUBLIC_VIDEO_SPEECH_CUE_FRAME_TOP_PERCENT=10
NEXT_PUBLIC_VIDEO_SPEECH_CUE_FRAME_WIDTH_PERCENT=32
NEXT_PUBLIC_VIDEO_SPEECH_CUE_FRAME_HEIGHT_PERCENT=74

# WS robustness tuning (server)
WS_HEARTBEAT_INTERVAL_MS=25000
WS_IDLE_TIMEOUT_MS=240000
